{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "removeComments": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "declaration": true
  },
  "include": ["credentials/**/*", "nodes/**/*", "nodes/**/*.json"],
  "exclude": ["dist/**/*", "node_modules/**/*"]
}
