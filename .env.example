# Open-Dispatch — adapter credentials
# Copy to .env and fill what you actually use. The API only complains when a target
# references a platform whose env vars aren't set.
#
# Account-scoped credentials: target "twitter:work" → TWITTER_ACCESS_TOKEN_WORK.

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_CHAT_ID_BROADCAST=

# ── Twitter / X ────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Instagram (Graph API; needs public media URLs) ─────────────────────────
IG_USER_ID=
IG_TOKEN=

# ── Bluesky (use App Password, not your main login password) ───────────────
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── LinkedIn (3-legged OAuth token with w_member_social) ───────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# ── Threads (Meta Threads Graph API) ───────────────────────────────────────
# Long-lived token with threads_basic + threads_content_publish scopes.
# Get via https://developers.facebook.com/docs/threads/getting-started
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
# THREADS_SETTLE_SECONDS=30   # delay before publishing the created container

# ── Worker tuning ──────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL=5
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_BASE=30

# ── Data dir (queue JSONL lives here) ──────────────────────────────────────
OPEN_DISPATCH_DATA=./data
